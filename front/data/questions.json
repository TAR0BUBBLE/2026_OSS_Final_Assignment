      "options": [
        {
          "label": "돌격: 팀의 앞에서 공간을 만들고 싶어요",
          "value": "tank"
        },
        {
          "label": "공격: 직접 적을 처치하고 싶어요",
          "value": "damage"
        },
        {
          "label": "지원: 아군을 살리고 보조하고 싶어요",
          "value": "support"
        },
        {
          "label": "아직 모르겠어요",
          "value": "flex"
        }
      ]
    },
    {
      "id": "range",
      "label": "어떤 거리에서 싸우는 것이 편한가요?",
      "widget": "select_slider",
      "options": [
        {
          "label": "근거리",
          "value": 1
        },
        {
          "label": "중거리",
          "value": 3
        },
        {
          "label": "장거리",
          "value": 5
        }
      ]
    },
    {
      "id": "aim",
      "label": "정확한 조준에 얼마나 자신 있나요?",
