          "value": "protection"
        },
        {
          "label": "강력한 치유",
          "value": "healing"
        },
        {
          "label": "적 방해와 전장 제어",
          "value": "control"
        },
        {
          "label": "쉬운 조작과 입문 난이도",
          "value": "easy"
        }
