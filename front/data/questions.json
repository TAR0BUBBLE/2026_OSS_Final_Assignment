        {
          "label": "후방",
          "value": "backline"
        },
        {
          "label": "측면·적 후방",
          "value": "flank"
        },
        {
          "label": "상황에 따라 달라요",
          "value": "flexible"
        }
      ]
    },
    {
      "id": "priority",
      "label": "영웅을 고를 때 가장 중요하게 생각하는 요소는 무엇인가요?",
      "widget": "radio",
      "options": [
        {
          "label": "높은 공격력",
          "value": "damage"
        },
        {
          "label": "튼튼한 생존력",
          "value": "survival"
        },
        {
