{
  "metadata": {
    "title": "Streamlit 추천 질문 정의",
    "answer_schema": {
      "role": "tank | damage | support | flex",
      "range": "1 | 3 | 5",
      "aim": "1~5",
      "mobility": "1~5",
      "aggression": "1~5",
      "position": "frontline | midline | backline | flank | flexible",
      "priority": "damage | survival | protection | healing | control | easy",
      "experience": "beginner | intermediate | advanced"
    }
  },
  "questions": [
    {
      "id": "role",
      "label": "가장 해보고 싶은 역할은 무엇인가요?",
