    },
    {
      "id": "experience",
      "label": "FPS 또는 오버워치 경험은 어느 정도인가요?",
      "widget": "radio",
      "options": [
        {
          "label": "입문자",
          "value": "beginner"
        },
        {
          "label": "중급자",
          "value": "intermediate"
        },
        {
          "label": "숙련자",
          "value": "advanced"
        }
      ]
    }
  ],
