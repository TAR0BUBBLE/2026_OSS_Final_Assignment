# syntax=docker/dockerfile:1

FROM python:3.11-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1

WORKDIR /app

COPY front/requirements.txt /app/front/requirements.txt

RUN python -m pip install --upgrade pip \
    && python -m pip install -r /app/front/requirements.txt

COPY front /app/front

EXPOSE 8501

CMD ["python", "-m", "streamlit", "run", "front/app.py", "--server.address=0.0.0.0", "--server.port=8501", "--server.headless=true", "--browser.gatherUsageStats=false"]
